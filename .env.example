# ── Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in values

# Backend
PORT=4000
NODE_ENV=development
JWT_SECRET=change-this-to-a-random-string-min-32-chars
ADMIN_SETUP_KEY=change-this-admin-setup-secret
CLIENT_URL=http://localhost:5173

# File Upload Settings
MAX_FILE_SIZE_MB=10
MAX_REQUEST_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif

# CORS Settings
CORS_ORIGIN=http://localhost:5173

# Default Admin Credentials (for auto-seed)
DEFAULT_ADMIN_NAME=admin
DEFAULT_ADMIN_PASSWORD=admin2026

# Database – use ONE of the following:
DB_NAME=scavenger-hunt
MONGODB_URI=mongodb://localhost:27017/scavenger-hunt
# AZURE_COSMOS_CONNECTIONSTRING=mongodb://your-cosmos-account:your-key@your-cosmos-account.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retryWrites=false

# Docker / Production overrides
# MONGODB_URI=mongodb://mongo:27017/scavenger-hunt
# CLIENT_URL=http://localhost

# Frontend (Vite)
VITE_API_URL=/api
